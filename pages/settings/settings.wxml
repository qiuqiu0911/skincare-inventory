<view class="page my-page">
  <view class="page-head">
    <view>
      <view class="page-title">我的</view>
      <view class="page-subtitle">快捷配置、分类产品和本机数据</view>
    </view>
  </view>

  <view class="settings-section-title">常用配置</view>
  <view class="settings-entry card" role="button" hover-class="tap-hover" bindtap="goTemplates">
    <view class="settings-entry-icon settings-entry-icon-template">
      <image src="/assets/icons/action-copy.svg" mode="aspectFit" alt="" />
    </view>
    <view class="settings-entry-main">
      <view class="settings-entry-title">快捷模板</view>
      <view class="settings-entry-meta">{{templatePreviewText}}</view>
    </view>
    <view class="settings-entry-side">
      <view class="settings-entry-count">{{templateCount}}</view>
      <view class="settings-entry-chevron">›</view>
    </view>
  </view>

  <view class="settings-entry card" role="button" hover-class="tap-hover" bindtap="goCategories">
    <view class="settings-entry-icon settings-entry-icon-category">
      <image src="/assets/icons/product-category.svg" mode="aspectFit" alt="" />
    </view>
    <view class="settings-entry-main">
      <view class="settings-entry-title">分类与产品</view>
      <view class="settings-entry-meta">{{categoryPreviewText}}</view>
      <view class="settings-entry-submeta">{{productSummaryText}}</view>
    </view>
    <view class="settings-entry-side">
      <view class="settings-entry-count">{{categoryCount}}</view>
      <view class="settings-entry-chevron">›</view>
    </view>
  </view>

  <view class="settings-section-title data-section-title">数据</view>
  <view class="data-note card card-soft">
    <view class="item-title">数据保存在本机</view>
    <view class="item-meta">记录、库存、分类和模板使用微信小程序本地存储持久化；不卸载小程序、不清理微信缓存时可长期保留。</view>
  </view>

  <view class="backup-card card">
    <view class="item-title">备份与恢复</view>
    <view class="item-meta">导出 JSON 备份文件，换设备或清理缓存后可从文件恢复。</view>
    <view class="backup-actions">
      <view class="backup-button backup-button-primary" role="button" hover-class="button-hover" aria-label="导出数据" bindtap="exportData">导出数据</view>
      <view class="backup-button" role="button" hover-class="button-hover" aria-label="导入数据(将覆盖本机数据)" bindtap="importData">导入数据</view>
      <view class="backup-button" role="button" hover-class="button-hover" aria-label="从剪贴板导入数据(将覆盖本机数据)" bindtap="importClipboardData">剪贴板导入</view>
    </view>
  </view>
</view>
