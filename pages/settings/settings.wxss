.my-page {
  min-height: 100vh;
}

.page-head {
  padding: 42rpx 18rpx 30rpx;
}

.page-title {
  color: #333333;
  font-size: 50rpx;
  font-weight: 750;
  line-height: 62rpx;
}

.page-subtitle {
  margin-top: 6rpx;
  color: #8b95a1;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 36rpx;
}

.category-form {
  margin: 0 10rpx 30rpx;
  padding: 24rpx;
  border-radius: 30rpx;
}

.category-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-input {
  flex: 1;
  min-width: 0;
  min-height: 86rpx;
  border-radius: 22rpx;
  background: #fafbfc;
  font-size: 28rpx;
}

.add-category {
  width: 136rpx;
  min-width: 136rpx;
  height: 86rpx;
  min-height: 86rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  background: #f5f6f8;
  color: #c7cdd5;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 86rpx;
  text-align: center;
  box-shadow: none;
}

.add-category-disabled {
  opacity: 0.62;
}

.add-category-active {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(17, 24, 39, 0.14);
}

.form-error {
  width: 100%;
}

.category-section {
  margin: 0 10rpx;
}

.section-line {
  margin: 0 8rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-name {
  color: #333333;
  font-size: 28rpx;
  font-weight: 750;
  line-height: 38rpx;
}

.section-count {
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.category-swipe-item {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.category-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  box-sizing: border-box;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.category-swipe-actions-active {
  opacity: 1;
  pointer-events: auto;
}

.category-row {
  position: relative;
  z-index: 1;
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 28rpx;
  transition: transform 0.18s ease;
}

.category-row-open {
  transform: translateX(-96rpx);
}

.category-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-width: 0;
}

.tag-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.category-name {
  color: #333333;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 40rpx;
  word-break: break-all;
}

.category-hint {
  flex-shrink: 0;
  color: #c0c7d0;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.category-delete-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #fff1f2;
}

.category-trash {
  position: relative;
  width: 30rpx;
  height: 34rpx;
}

.category-trash-lid {
  position: absolute;
  left: 3rpx;
  top: 3rpx;
  width: 24rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ef4444;
}

.category-trash-lid::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -5rpx;
  width: 8rpx;
  height: 5rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #ef4444;
}

.category-trash-body {
  position: absolute;
  left: 5rpx;
  top: 12rpx;
  width: 20rpx;
  height: 18rpx;
  border: 4rpx solid #ef4444;
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.delete-button-disabled {
  opacity: 0.45;
}

.my-tip {
  margin: 28rpx 38rpx 36rpx;
  color: #a3adbb;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 36rpx;
}

.data-note {
  margin: 0 10rpx;
  border-radius: 28rpx;
  box-shadow: none;
}

.backup-card {
  margin: 24rpx 10rpx 0;
  border-radius: 28rpx;
}

.backup-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.backup-button {
  flex: 1;
  min-height: 76rpx;
  border-radius: 20rpx;
  background: #f5f6f8;
  color: #333333;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.backup-button-primary {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(17, 24, 39, 0.14);
}
