.review-page {
  min-height: 100vh;
}

.page-head {
  padding: 44rpx 18rpx 34rpx;
}

.page-title {
  color: #333333;
  font-size: 50rpx;
  font-weight: 750;
  line-height: 62rpx;
}

.page-date {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 34rpx;
}

.review-tabs {
  margin: 0 18rpx 34rpx;
  border-radius: 24rpx;
}

.tab-icon {
  margin-right: 10rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.day-card {
  padding: 34rpx;
  border-radius: 28rpx;
}

.day-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 26rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.05);
}

.day-title {
  color: #333333;
  font-size: 36rpx;
  font-weight: 750;
  line-height: 46rpx;
}

.day-date {
  color: #9ca3af;
  font-size: 26rpx;
  line-height: 36rpx;
}

.slot-block {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 20rpx;
}

.slot-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #f9fafb;
  text-align: center;
  line-height: 48rpx;
  font-size: 24rpx;
}

.sun {
  color: #f59e0b;
}

.moon {
  color: #818cf8;
}

.slot-list {
  flex: 1;
  min-width: 0;
}

.slot-row {
  color: #333333;
  font-size: 28rpx;
  line-height: 42rpx;
  word-break: break-all;
}

.slot-amount {
  margin-left: 16rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.empty-line {
  color: #9ca3af;
  font-size: 26rpx;
  line-height: 38rpx;
}

.week-card {
  padding: 34rpx;
  border-radius: 28rpx;
}

.week-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 34rpx;
}

.week-title {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 36rpx;
}

.week-range {
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 32rpx;
}

.week-grid-head,
.week-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.week-grid-head {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.05);
  color: #9ca3af;
  font-size: 20rpx;
}

.week-row {
  min-height: 62rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.04);
}

.week-row:last-of-type {
  border-bottom: 0;
}

.product-col {
  width: 170rpx;
  flex-shrink: 0;
}

.product-name {
  overflow: hidden;
  color: #333333;
  font-size: 24rpx;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-cols {
  flex: 1;
  display: flex;
  justify-content: space-between;
  min-width: 0;
}

.day-col {
  width: 40rpx;
  display: flex;
  justify-content: center;
  text-align: center;
}

.today-col {
  color: #333333;
  font-weight: 750;
}

.usage-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
}

.usage-dot-on {
  background: #3b82f6;
  box-shadow: 0 0 0 5rpx rgba(59, 130, 246, 0.1);
}

.week-summary {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #f9fafb;
}

.summary-kicker {
  color: #9ca3af;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.summary-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}

.summary-box {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
}

.summary-value {
  color: #333333;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 36rpx;
}

.summary-label {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 18rpx;
  line-height: 28rpx;
}
