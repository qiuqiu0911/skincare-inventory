.review-page {
  min-height: 100vh;
}

.page-head {
  padding: 44rpx 18rpx 34rpx;
}

.page-title {
  color: #333333;
  font-size: 50rpx;
  font-weight: 750;
  line-height: 62rpx;
}

.page-date {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 25rpx;
  line-height: 36rpx;
}

.review-tabs {
  margin: 0 18rpx 34rpx;
  border-radius: 24rpx;
}

.tab-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 9rpx;
  flex-shrink: 0;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.day-card {
  padding: 34rpx;
  border-radius: 28rpx;
}

.day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 26rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.05);
}

.day-title {
  color: #333333;
  font-size: 36rpx;
  font-weight: 750;
  line-height: 46rpx;
}

.day-date {
  color: #9ca3af;
  font-size: 25rpx;
  line-height: 36rpx;
}

.makeup-button {
  min-width: 88rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 52rpx;
  flex-shrink: 0;
}

.slot-block {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 20rpx;
}

.slot-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  padding: 11rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  box-sizing: border-box;
}

.sun {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.moon {
  background: rgba(129, 140, 248, 0.1);
  color: #818cf8;
}

.slot-list {
  flex: 1;
  min-width: 0;
}

.slot-row {
  color: #333333;
  font-size: 29rpx;
  line-height: 40rpx;
  word-break: break-all;
}

.slot-amount {
  margin-left: 16rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 32rpx;
}

.empty-line {
  color: #9ca3af;
  font-size: 25rpx;
  line-height: 36rpx;
}

.week-card {
  padding: 34rpx;
  border-radius: 28rpx;
}

.week-panel {
  min-height: 320rpx;
}

.week-empty {
  margin: 0;
  border-radius: 28rpx;
}

.week-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.week-title {
  color: #6b7280;
  font-size: 25rpx;
  line-height: 36rpx;
}

.week-range {
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 34rpx;
}

.week-legend {
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 28rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-half {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
}

.legend-morning {
  border-radius: 999rpx 0 0 999rpx;
  background: #f59e0b;
}

.legend-evening {
  border-radius: 0 999rpx 999rpx 0;
  background: #818cf8;
}

.week-grid-head,
.week-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.week-grid-head {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.05);
  color: #9ca3af;
  font-size: 22rpx;
}

.week-row {
  min-height: 62rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.04);
}

.week-row:last-of-type {
  border-bottom: 0;
}

.product-col {
  width: 170rpx;
  flex-shrink: 0;
}

.product-name {
  overflow: hidden;
  color: #333333;
  font-size: 25rpx;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-cols {
  flex: 1;
  display: flex;
  justify-content: space-between;
  min-width: 0;
}

.day-col {
  width: 40rpx;
  display: flex;
  justify-content: center;
  text-align: center;
}

.today-col {
  color: #333333;
  font-weight: 750;
}

.usage-circle {
  width: 22rpx;
  height: 22rpx;
  display: flex;
  overflow: hidden;
  border-radius: 999rpx;
  box-shadow: 0 0 0 4rpx rgba(17, 24, 39, 0.025);
}

.usage-half {
  width: 50%;
  height: 100%;
  background: #e5e7eb;
}

.usage-half-morning-on {
  background: #f59e0b;
}

.usage-half-evening-on {
  background: #818cf8;
}

.week-summary {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #f9fafb;
}

.summary-kicker {
  color: #9ca3af;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.summary-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}

.summary-box {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
}

.summary-value {
  color: #333333;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 36rpx;
}

.summary-label {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 30rpx;
}
