.review-page {
  min-height: 100vh;
}

.review-page-compact {
  height: 100vh;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.review-page-compact .page-head,
.review-page-compact .review-tabs {
  flex-shrink: 0;
}

.review-tabs {
  margin-bottom: var(--space-7);
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

/* ========== 三日列表 ========== */
.recent-list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: stretch;
  gap: var(--space-3);
}

.review-page-compact .recent-list {
  flex: 1;
  min-height: 0;
}

.day-card {
  min-width: 0;
  min-height: 0;
  padding: var(--space-4) var(--space-3);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.day-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--color-border-subtle);
  flex-shrink: 0;
}

.day-title {
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  font-weight: var(--fw-bold);
  line-height: var(--lh-body);
}

.day-date {
  margin-top: var(--space-1);
  color: var(--color-text-tertiary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
}

.makeup-button {
  min-width: 56rpx;
  height: 40rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--space-1);
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: 20rpx;
  font-weight: var(--fw-semibold);
  line-height: 40rpx;
  flex-shrink: 0;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.slot-block {
  min-width: 0;
  min-height: 0;
  flex: 1;
  margin-top: 0;
  padding: var(--space-3) var(--space-2);
  border: 1rpx solid var(--color-border-subtle);
  border-radius: var(--radius-sm);
  background: var(--color-surface-soft);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.slot-block + .slot-block {
  margin-top: var(--space-3);
}

.slot-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  min-height: 44rpx;
  margin-bottom: var(--space-2);
  padding: 0;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.slot-title-icon {
  width: 26rpx;
  height: 26rpx;
}

.slot-list {
  min-height: 0;
  overflow: hidden;
}

.morning-title {
  color: var(--color-routine-morning);
  background: var(--color-routine-morning-soft);
}

.evening-title {
  color: var(--color-routine-evening);
  background: var(--color-routine-evening-soft);
}

.slot-row {
  position: relative;
  padding-left: var(--space-4);
  color: var(--color-text-primary);
  font-size: 22rpx;
  line-height: 30rpx;
  word-break: break-all;
}

.slot-row::before {
  content: "·";
  position: absolute;
  left: 0;
  top: 0;
  color: var(--color-text-secondary);
  font-weight: var(--fw-bold);
}

.slot-amount {
  margin-left: var(--space-2);
  color: var(--color-text-tertiary);
  font-size: 20rpx;
  line-height: 28rpx;
}

.empty-line {
  color: var(--color-text-tertiary);
  font-size: 21rpx;
  line-height: 30rpx;
}

/* ========== 周视图 ========== */
.week-card {
  padding: var(--space-6);
  border-radius: var(--radius-lg);
}

.week-panel {
  min-height: 320rpx;
}

.week-empty {
  margin: 0;
  border-radius: var(--radius-lg);
}

.week-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
}

.week-title {
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  line-height: var(--lh-body);
}

.week-range {
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
}

.week-legend {
  margin-bottom: var(--space-5);
  display: flex;
  align-items: center;
  gap: var(--space-5);
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  line-height: var(--lh-caption);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.legend-half {
  width: 24rpx;
  height: 24rpx;
  border-radius: var(--radius-pill);
}

.legend-morning {
  border-radius: var(--radius-pill) 0 0 var(--radius-pill);
  background: var(--color-routine-morning);
}

.legend-evening {
  border-radius: 0 var(--radius-pill) var(--radius-pill) 0;
  background: var(--color-routine-evening);
}

.week-grid-head,
.week-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.week-grid-head {
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--color-border-subtle);
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
}

.week-row {
  min-height: 64rpx;
  border-bottom: 1rpx solid var(--color-border-subtle);
}

.week-row:last-of-type {
  border-bottom: 0;
}

.product-col {
  width: 200rpx;
  flex-shrink: 0;
}

.product-name {
  overflow: hidden;
  color: var(--color-text-primary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-cols {
  flex: 1;
  display: flex;
  justify-content: space-between;
  min-width: 0;
}

.day-col {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.today-col {
  color: var(--color-text-primary);
  font-weight: var(--fw-bold);
}

.usage-circle {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  overflow: hidden;
  border-radius: var(--radius-pill);
  box-shadow: 0 0 0 2rpx var(--color-border-subtle);
}

.usage-half {
  width: 50%;
  height: 100%;
  background: var(--color-surface-muted);
}

.usage-half-morning-on {
  background: var(--color-routine-morning);
}

.usage-half-evening-on {
  background: var(--color-routine-evening);
}

/* ========== 周总结 ========== */
.week-summary {
  margin-top: var(--space-6);
  padding: var(--space-5);
  border-radius: var(--radius-lg);
  background: var(--color-surface-soft);
}

.summary-kicker {
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.summary-grid {
  display: flex;
  gap: var(--space-4);
  margin-top: var(--space-4);
}

.summary-box {
  flex: 1;
  min-width: 0;
  padding: var(--space-5);
  border-radius: var(--radius-md);
  background: var(--color-surface-elevated);
  text-align: center;
}

.summary-value {
  color: var(--color-text-primary);
  font-size: var(--fs-title);
  font-weight: var(--fw-bold);
  line-height: var(--lh-title);
}

.summary-label {
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
}
