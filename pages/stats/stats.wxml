<view class="page review-page {{activeTab === '3days' ? 'review-page-compact' : ''}}">
  <view class="page-head">
    <view>
      <view class="page-title">{{pageTitle}}</view>
      <view class="page-date">{{rangeText}}</view>
    </view>
  </view>

  <view class="segmented review-tabs" role="tablist">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="segmented-item {{activeTab === item.value ? 'segmented-item-active' : ''}}"
      role="tab"
      aria-selected="{{activeTab === item.value}}"
      data-value="{{item.value}}"
      bindtap="switchTab"
      hover-class="tap-hover"
    >
      <image
        class="tab-icon"
        src="{{activeTab === item.value ? item.activeIconPath : item.iconPath}}"
        mode="aspectFit"
        alt=""
      />
      <text>{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{activeTab === '3days'}}" class="recent-list">
    <view class="day-card card" wx:for="{{threeDays}}" wx:key="date">
      <view class="day-head">
        <view>
          <view class="day-title">{{item.label}}</view>
          <view class="day-date">{{item.shortDate}}</view>
        </view>
        <view
          class="makeup-button"
          role="button"
          hover-class="tap-hover"
          aria-label="为 {{item.label}} {{item.shortDate}} 补记"
          data-date="{{item.date}}"
          bindtap="addRecordForDay"
        >补记</view>
      </view>
      <view class="slot-block">
        <view class="slot-title morning-title">
          <image class="slot-title-icon" src="/assets/icons/time-morning.png" mode="aspectFit" alt="早间" />
        </view>
        <view class="slot-list">
          <view class="slot-row" wx:for="{{item.morning}}" wx:key="id">
            <text>{{item.productNameSnapshot}}</text>
            <text class="slot-amount" wx:if="{{item.amount}}">{{item.amount}}</text>
          </view>
          <view class="empty-line" wx:if="{{!item.morning.length}}">未记录</view>
        </view>
      </view>
      <view class="slot-block">
        <view class="slot-title evening-title">
          <image class="slot-title-icon" src="/assets/icons/time-evening.png" mode="aspectFit" alt="晚间" />
        </view>
        <view class="slot-list">
          <view class="slot-row" wx:for="{{item.evening}}" wx:key="id">
            <text>{{item.productNameSnapshot}}</text>
            <text class="slot-amount" wx:if="{{item.amount}}">{{item.amount}}</text>
          </view>
          <view class="empty-line" wx:if="{{!item.evening.length}}">未记录</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'month'}}" class="month-panel">
    <view class="calendar-card card">
      <view class="calendar-head">
        <view
          class="calendar-nav-button"
          role="button"
          hover-class="tap-hover"
          aria-label="上个月"
          bindtap="goPreviousMonth"
        >‹</view>
        <view class="calendar-title-block">
          <view class="calendar-title">{{calendar.monthLabel}}</view>
          <view class="calendar-subtitle">{{calendar.summaryText}}</view>
        </view>
        <view
          class="calendar-nav-button"
          role="button"
          hover-class="tap-hover"
          aria-label="下个月"
          bindtap="goNextMonth"
        >›</view>
      </view>
      <view class="calendar-weekdays">
        <view wx:for="{{calendar.weekdays}}" wx:key="*this" class="calendar-weekday">周{{item}}</view>
      </view>
      <view class="calendar-grid">
        <view
          wx:for="{{calendar.cells}}"
          wx:key="key"
          class="{{item.className}}"
          role="button"
          hover-class="tap-hover"
          aria-label="{{item.ariaLabel}}"
          data-date="{{item.date}}"
          bindtap="selectCalendarDay"
        >
          <text class="calendar-day-number">{{item.day}}</text>
          <view class="calendar-usage-mark" wx:if="{{item.hasRecords}}">
            <text class="{{item.morningClass}}"></text>
            <text class="{{item.eveningClass}}"></text>
          </view>
          <text class="calendar-record-count" wx:if="{{item.recordCount}}">{{item.recordCount}}</text>
        </view>
      </view>
      <view class="calendar-actions">
        <picker mode="date" value="{{selectedDay.date}}" bindchange="onCalendarDatePick">
          <view class="calendar-picker-button" role="button" hover-class="tap-hover">切换日期 ›</view>
        </picker>
        <view
          class="calendar-today-button"
          role="button"
          hover-class="tap-hover"
          bindtap="goCurrentMonth"
        >回到今天</view>
      </view>
    </view>

    <view class="selected-day-card card">
      <view class="selected-day-head">
        <view class="selected-day-title-block">
          <view class="selected-day-title">{{selectedDay.title}}</view>
          <view class="selected-day-meta">{{selectedDay.metaText}}</view>
        </view>
        <view
          class="makeup-button"
          role="button"
          hover-class="tap-hover"
          aria-label="为 {{selectedDay.date}} 补记"
          data-date="{{selectedDay.date}}"
          bindtap="addRecordForDay"
        >补记</view>
      </view>
      <view class="selected-day-slots">
        <view class="slot-block selected-slot-block">
          <view class="slot-title morning-title">
            <image class="slot-title-icon" src="/assets/icons/time-morning.png" mode="aspectFit" alt="早间" />
          </view>
          <view class="slot-list">
            <view class="slot-row" wx:for="{{selectedDay.morning}}" wx:key="id">
              <text>{{item.productNameSnapshot}}</text>
              <text class="slot-amount" wx:if="{{item.amount}}">{{item.amount}}</text>
            </view>
            <view class="empty-line" wx:if="{{!selectedDay.morning.length}}">未记录</view>
          </view>
        </view>
        <view class="slot-block selected-slot-block">
          <view class="slot-title evening-title">
            <image class="slot-title-icon" src="/assets/icons/time-evening.png" mode="aspectFit" alt="晚间" />
          </view>
          <view class="slot-list">
            <view class="slot-row" wx:for="{{selectedDay.evening}}" wx:key="id">
              <text>{{item.productNameSnapshot}}</text>
              <text class="slot-amount" wx:if="{{item.amount}}">{{item.amount}}</text>
            </view>
            <view class="empty-line" wx:if="{{!selectedDay.evening.length}}">未记录</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{activeTab === 'week'}}"
    class="week-panel"
    bindtouchstart="onWeekTouchStart"
    bindtouchend="onWeekTouchEnd"
  >
    <view class="week-card card" wx:if="{{week.rows.length}}">
      <view class="week-head">
        <view class="week-title">本周使用概览</view>
        <view class="week-range">{{week.start}} - {{week.end}}</view>
      </view>
      <view class="week-legend">
        <view class="legend-item"><text class="legend-half legend-morning"></text><text>左早</text></view>
        <view class="legend-item"><text class="legend-half legend-evening"></text><text>右晚</text></view>
      </view>
      <view class="week-grid-head">
        <view class="product-col">产品名称</view>
        <view class="day-cols">
          <view
            wx:for="{{week.days}}"
            wx:key="date"
            class="day-col {{item.isToday ? 'today-col' : ''}}"
          >{{item.label}}</view>
        </view>
      </view>
      <view class="week-row" wx:for="{{week.rows}}" wx:key="productName">
        <view class="product-col product-name">{{item.productName}}</view>
        <view class="day-cols">
          <view wx:for="{{item.cells}}" wx:key="date" class="day-col">
            <view class="usage-circle">
              <view class="usage-half usage-half-morning {{item.morning ? 'usage-half-morning-on' : ''}}"></view>
              <view class="usage-half usage-half-evening {{item.evening ? 'usage-half-evening-on' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>
      <view class="week-summary">
        <view class="summary-kicker">本周总结</view>
        <view class="summary-grid">
          <view class="summary-box">
            <view class="summary-value">{{week.recordCount}}</view>
            <view class="summary-label">记录天次</view>
          </view>
          <view class="summary-box">
            <view class="summary-value">{{week.productCount}}</view>
            <view class="summary-label">使用产品</view>
          </view>
        </view>
      </view>
    </view>
    <view class="card empty-state week-empty" wx:else>
      <view class="empty-title">本周还没有记录</view>
      <view class="empty-text">{{week.start}} - {{week.end}} 暂无记录。</view>
      <button class="primary empty-action" hover-class="button-hover" bindtap="goToday">去记录</button>
    </view>
  </view>
</view>
