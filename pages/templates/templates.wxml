<view class="page template-page">
  <view class="page-head">
    <view>
      <view class="page-title">快捷模板</view>
      <view class="page-subtitle">每日记录时一键套用常用步骤</view>
    </view>
    <view
      class="template-create-button"
      role="button"
      hover-class="tap-hover"
      bindtap="openCreateTemplateForm"
    >新建</view>
  </view>

  <view class="template-manage-list" wx:if="{{templates.length}}">
    <view class="template-manage-row card" wx:for="{{templates}}" wx:key="id">
      <view class="template-manage-info">
        <view class="template-manage-title">{{item.name}}</view>
        <view class="template-manage-meta">{{item.timeText}} · {{item.itemCount}} 项 · {{item.previewText}}</view>
      </view>
      <view class="template-row-actions">
        <view
          class="template-edit-button"
          role="button"
          hover-class="tap-hover"
          data-id="{{item.id}}"
          bindtap="editTemplate"
        >编辑</view>
        <view
          class="template-delete-button"
          role="button"
          hover-class="tap-hover"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="deleteTemplate"
        >删除</view>
      </view>
    </view>
  </view>
  <view class="card empty-state" wx:else>
    <view class="empty-title">还没有模板</view>
    <view class="empty-text">可从今日页把当前记录保存为模板，也可以在这里新建。</view>
    <view class="empty-action template-create-button" role="button" hover-class="tap-hover" bindtap="openCreateTemplateForm">新建模板</view>
  </view>

  <view class="sheet-mask" wx:if="{{showTemplateForm}}" bindtap="closeTemplateForm"></view>
  <view
    class="bottom-sheet template-form-sheet"
    wx:if="{{showTemplateForm}}"
    role="dialog"
    aria-modal="true"
    catchtouchmove="noop"
  >
    <view class="sheet-head">
      <view class="sheet-title">{{editingTemplateId ? '编辑模板' : '新建模板'}}</view>
      <button
        class="close-button"
        hover-class="button-hover"
        aria-label="关闭"
        bindtap="closeTemplateForm"
      >×</button>
    </view>

    <view class="field">
      <text class="field-label">模板名称</text>
      <input placeholder="例如：日常早 C" value="{{templateForm.name}}" bindinput="onTemplateNameInput" />
      <view class="field-error" wx:if="{{templateError}}">{{templateError}}</view>
    </view>

    <view class="segmented template-time-tabs">
      <view
        wx:for="{{templateTimeOptions}}"
        wx:key="value"
        class="segmented-item {{templateForm.timeOfDay === item.value ? 'segmented-item-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="switchTemplateTime"
        hover-class="tap-hover"
      >{{item.label}}</view>
    </view>

    <view class="template-items-head">
      <view class="section-name">产品内容</view>
      <view
        class="template-add-item"
        role="button"
        hover-class="tap-hover"
        bindtap="addTemplateItem"
      >添加产品</view>
    </view>
    <view class="template-form-item" wx:for="{{templateForm.items}}" wx:key="index">
      <view class="template-item-line">
        <view class="template-item-index">{{index + 1}}</view>
        <picker
          class="picker-bare template-category-picker-wrap"
          range="{{categoryNames}}"
          value="{{item.categoryIndex}}"
          data-index="{{index}}"
          bindchange="onTemplateItemCategoryPick"
        >
          <view class="template-category-picker" role="button" hover-class="tap-hover">
            <text>{{item.categoryName}}</text>
            <text class="picker-chevron">›</text>
          </view>
        </picker>
        <input
          class="template-amount-input"
          placeholder="用量"
          value="{{item.amount}}"
          data-index="{{index}}"
          data-field="amount"
          bindinput="onTemplateItemInput"
        />
        <view
          class="template-remove-item"
          role="button"
          hover-class="tap-hover"
          data-index="{{index}}"
          bindtap="removeTemplateItem"
        >×</view>
      </view>
      <view class="template-item-line template-item-subline">
        <input
          class="template-product-input"
          placeholder="产品名称"
          value="{{item.productName}}"
          data-index="{{index}}"
          data-field="productName"
          bindinput="onTemplateItemInput"
        />
        <view
          class="template-history-button"
          role="button"
          hover-class="tap-hover"
          data-index="{{index}}"
          bindtap="openTemplateProductSelector"
        >历史</view>
      </view>
      <view
        class="template-product-selector"
        wx:if="{{showTemplateProductSelector && templateProductSelectorIndex === index}}"
      >
        <view class="template-product-selector-head">
          <view class="template-product-selector-title">{{item.categoryName}}历史产品</view>
          <view
            class="template-product-selector-close"
            role="button"
            hover-class="tap-hover"
            bindtap="closeTemplateProductSelector"
          >×</view>
        </view>
        <input
          class="template-product-search-input"
          placeholder="搜索产品名称"
          value="{{templateProductSearchKeyword}}"
          bindinput="onTemplateProductSearchInput"
        />
        <scroll-view
          scroll-y
          class="template-product-option-list {{filteredTemplateProductOptions.length <= 3 ? 'template-product-option-list-compact' : ''}}"
        >
          <view
            wx:for="{{filteredTemplateProductOptions}}"
            wx:for-item="productName"
            wx:key="*this"
            class="template-product-option"
            role="button"
            hover-class="tap-hover"
            data-name="{{productName}}"
            bindtap="selectTemplateProduct"
          >{{productName}}</view>
          <view wx:if="{{!filteredTemplateProductOptions.length}}" class="template-product-option-empty">
            没有匹配的历史产品
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="sheet-actions">
      <button class="secondary" hover-class="button-hover" bindtap="closeTemplateForm">取消</button>
      <button
        class="primary"
        hover-class="button-hover"
        disabled="{{!canSubmitTemplate}}"
        aria-disabled="{{!canSubmitTemplate}}"
        bindtap="submitTemplateForm"
      >保存</button>
    </view>
  </view>
</view>
