.today-page {
  min-height: 100vh;
}

.page-head {
  padding: 44rpx 18rpx 34rpx;
}

.page-title {
  color: #333333;
  font-size: 50rpx;
  font-weight: 750;
  line-height: 62rpx;
}

.page-date {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 34rpx;
}

.time-tabs {
  margin: 0 18rpx 34rpx;
  border-radius: 24rpx;
}

.time-icon {
  margin-right: 10rpx;
}

.time-icon-sun {
  color: #f59e0b;
}

.time-icon-moon {
  color: #818cf8;
}

.record-card {
  margin: 0 8rpx;
  background: #f9fafb;
  border-color: transparent;
  box-shadow: none;
}

.record-card-head {
  margin-bottom: 16rpx;
}

.record-count {
  color: #9ca3af;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.record-row {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.05);
}

.record-row:first-of-type {
  border-top: 0;
}

.record-name {
  flex: 1;
  min-width: 0;
  color: #6b7280;
  font-size: 27rpx;
  line-height: 36rpx;
  word-break: break-all;
}

.record-side {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.record-amount {
  max-width: 150rpx;
  color: #333333;
  font-size: 25rpx;
  line-height: 34rpx;
  word-break: break-all;
}

.icon-button {
  min-width: 44rpx;
  min-height: 44rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 44rpx;
}

.danger-icon {
  color: #ef4444;
}

.empty-record {
  height: 280rpx;
  margin: 12rpx 4rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 126rpx;
  padding: 0 48rpx;
  z-index: 5;
  box-sizing: border-box;
}

.add-dashed {
  width: 100%;
  min-height: 168rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #e5e7eb;
  border-radius: 32rpx;
  background: #ffffff;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 34rpx;
  box-shadow: 0 12rpx 26rpx rgba(17, 24, 39, 0.045);
}

.add-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
  line-height: 56rpx;
  font-size: 30rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.2);
}

.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  max-height: 90vh;
  padding: 44rpx 38rpx 42rpx;
  border-radius: 64rpx 64rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(17, 24, 39, 0.12);
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.sheet-title {
  color: #333333;
  font-size: 40rpx;
  font-weight: 750;
  line-height: 50rpx;
}

.close-button {
  min-width: 64rpx;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  color: #9ca3af;
  font-size: 40rpx;
  line-height: 64rpx;
}

.sheet-time-tabs {
  margin-bottom: 28rpx;
  border-radius: 24rpx;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.field-line .field-label {
  margin-bottom: 0;
}

.history-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 10rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.sheet-actions {
  display: flex;
  gap: 18rpx;
  padding-top: 12rpx;
}

.sheet-actions button {
  flex: 1;
}
