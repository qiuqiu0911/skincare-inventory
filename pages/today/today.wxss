.today-page {
  min-height: 100vh;
}

.time-tabs {
  margin-bottom: var(--space-6);
}

.time-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

/* ========== 已记录卡片 ========== */
.record-card {
  background: var(--color-surface-soft);
  border-color: transparent;
  box-shadow: none;
  padding: var(--space-5);
}

.record-card-head {
  margin-bottom: var(--space-4);
}

.record-count {
  color: var(--color-text-tertiary);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ========== 滑动行 ========== */
.record-swipe-item {
  position: relative;
  overflow: hidden;
}

.record-swipe-item:first-of-type .record-row {
  border-top: 0;
}

.record-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-3);
  width: 200rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.record-swipe-actions-active {
  opacity: 1;
  pointer-events: auto;
}

.record-row {
  position: relative;
  z-index: 1;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-3) 0;
  background: var(--color-surface-soft);
  border-top: 1rpx solid var(--color-border-subtle);
  transition: transform var(--motion-fast) var(--ease-standard);
}

.record-row-open {
  transform: translateX(-200rpx);
}

.record-name {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  word-break: break-all;
}

.record-side {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.record-amount {
  max-width: 220rpx;
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
  word-break: break-all;
}

/* ========== 滑动按钮（≥88rpx 命中区） ========== */
.record-swipe-button {
  width: 88rpx;
  height: 88rpx;
  min-width: 88rpx;
  min-height: 88rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background: var(--color-surface-elevated);
  box-shadow: var(--shadow-xs);
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.record-swipe-edit {
  background: var(--color-surface-elevated);
}

.record-swipe-delete {
  background: var(--color-danger-bg);
}

.record-action-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== 空态 ========== */
.empty-record {
  height: 280rpx;
  margin-top: var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
}

.empty-record .empty-title {
  color: var(--color-text-primary);
  font-size: var(--fs-subtitle);
  line-height: var(--lh-subtitle);
}

.empty-record .empty-text {
  margin-top: var(--space-2);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
  text-align: center;
}

/* ========== 底部添加按钮 ========== */
.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 0 var(--page-padding-x);
  z-index: 5;
  box-sizing: border-box;
}

.add-dashed {
  width: 100%;
  min-height: 168rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed var(--color-border-default);
  border-radius: var(--radius-lg);
  background: var(--color-surface-elevated);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
  font-weight: var(--fw-semibold);
  box-shadow: var(--shadow-sm);
  padding: var(--space-5);
}

.add-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: var(--space-2);
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-pill);
  line-height: 52rpx;
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

/* ========== Sheet 表单 ========== */
.sheet-time-tabs {
  margin-bottom: var(--space-5);
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-2);
}

.field-line .field-label {
  margin-bottom: 0;
}

.history-chip {
  position: relative;
  min-height: 56rpx;
  padding: 0 var(--space-4);
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  border-radius: var(--radius-pill);
  background: var(--color-brand-accent-soft);
  color: var(--color-brand-accent-strong);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  line-height: 1;
}

.history-chip::before {
  content: '↻';
  font-size: 24rpx;
  font-weight: var(--fw-regular);
}

.history-chip::after {
  content: '';
  position: absolute;
  top: -16rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -16rpx;
}
