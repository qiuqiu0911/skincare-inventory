.today-page {
  min-height: 100vh;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.page-head {
  padding: var(--space-6) 0 var(--space-5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

.date-title-block {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.date-nav-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  background: var(--color-surface-elevated);
  color: var(--color-text-primary);
  font-size: 46rpx;
  font-weight: 500;
  line-height: 64rpx;
  box-shadow: var(--shadow-xs);
  transition: opacity var(--motion-fast) var(--ease-standard), transform var(--motion-fast) var(--ease-standard);
}

.date-nav-button:active {
  transform: scale(0.94);
}

.date-nav-button-disabled {
  opacity: 0.24;
  pointer-events: none;
}

.page-title {
  color: var(--color-text-primary);
  font-size: var(--fs-display);
  font-weight: var(--fw-bold);
  line-height: var(--lh-display);
}

.page-date {
  margin-top: var(--space-1);
  color: var(--color-text-tertiary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
}

.time-tabs {
  margin-bottom: var(--space-6);
}

.time-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

/* ========== 已记录卡片 ========== */
.record-card {
  background: var(--color-surface-soft);
  border-color: transparent;
  box-shadow: none;
  padding: var(--space-5);
}

.record-card-head {
  margin-bottom: var(--space-4);
}

.record-count {
  color: var(--color-text-tertiary);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ========== 滑动行 ========== */
.record-swipe-item {
  position: relative;
  overflow: hidden;
}

.record-swipe-item:first-of-type .record-row {
  border-top: 0;
}

.record-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-3);
  width: 200rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.record-swipe-actions-active {
  opacity: 1;
  pointer-events: auto;
}

.record-row {
  position: relative;
  z-index: 1;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-3) 0;
  background: var(--color-surface-soft);
  border-top: 1rpx solid var(--color-border-subtle);
  transition: transform var(--motion-fast) var(--ease-standard);
}

.record-row-open {
  transform: translateX(-200rpx);
}

.record-row-dragging {
  z-index: 2;
  background: var(--color-surface-elevated);
  box-shadow: var(--shadow-sm);
}

.record-name {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  word-break: break-all;
}

.record-side {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.record-amount {
  max-width: 220rpx;
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
  word-break: break-all;
}

.record-drag-handle {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  color: var(--color-text-tertiary);
  font-size: 36rpx;
  line-height: 1;
}

/* ========== 滑动按钮（≥88rpx 命中区） ========== */
.record-swipe-button {
  width: 88rpx;
  height: 88rpx;
  min-width: 88rpx;
  min-height: 88rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background: var(--color-surface-elevated);
  box-shadow: var(--shadow-xs);
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.record-swipe-edit {
  background: var(--color-surface-elevated);
}

.record-swipe-delete {
  background: var(--color-danger-bg);
}

.record-action-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== 空态 ========== */
.empty-record {
  height: 280rpx;
  margin-top: var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
}

.empty-record .empty-title {
  color: var(--color-text-primary);
  font-size: var(--fs-subtitle);
  line-height: var(--lh-subtitle);
}

.empty-record .empty-text {
  margin-top: var(--space-2);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
  text-align: center;
}

/* ========== 底部添加按钮 ========== */
.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  padding: var(--space-3) var(--page-padding-x) var(--space-4);
  z-index: 5;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: var(--space-4);
  background: rgba(250, 248, 244, 0.94);
  border-top: 1rpx solid var(--color-border-subtle);
}

.copy-yesterday-button {
  flex: 1;
  height: 96rpx;
  min-width: 0;
  min-height: 96rpx;
  padding: 0 var(--space-5);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #ffffff 0%, #f7f4ee 100%);
  border: 1rpx solid var(--color-border-subtle);
  color: var(--color-brand-accent-strong);
  box-shadow: var(--shadow-sm);
  gap: var(--space-2);
}

.add-record-button {
  flex: 1;
  min-width: 0;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 0 var(--space-5);
}

.bottom-action button {
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
}

.bottom-action text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bottom-action-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.add-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-pill);
  line-height: 34rpx;
  font-size: 30rpx;
  color: var(--color-text-inverse);
}

/* ========== Sheet 表单 ========== */
.today-page .bottom-sheet {
  overflow-y: auto;
}

.sheet-time-tabs {
  margin-bottom: var(--space-5);
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-2);
}

.field-line .field-label {
  margin-bottom: 0;
}

.history-chip {
  position: relative;
  min-height: 56rpx;
  padding: 0 var(--space-4);
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  border-radius: var(--radius-pill);
  background: var(--color-brand-accent-soft);
  color: var(--color-brand-accent-strong);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  line-height: 1;
}

.history-chip::before {
  content: '↻';
  font-size: 24rpx;
  font-weight: var(--fw-regular);
}

.history-chip::after {
  content: '';
  position: absolute;
  top: -16rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -16rpx;
}

.product-selector {
  margin: calc(-1 * var(--space-2)) 0 var(--space-5);
  padding: var(--space-4);
  border: 1rpx solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  background: var(--color-surface-soft);
  box-sizing: border-box;
}

.product-selector-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-3);
}

.product-selector-title {
  color: var(--color-text-primary);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  line-height: var(--lh-body-sm);
}

.product-selector-close {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: 32rpx;
  line-height: 1;
}

.product-search-input {
  min-height: 76rpx;
  margin-bottom: var(--space-3);
  background: var(--color-surface-elevated);
}

.product-option-list {
  height: 360rpx;
}

.product-option {
  min-height: var(--tap-min);
  display: flex;
  align-items: center;
  padding: 0 var(--space-4);
  border-top: 1rpx solid var(--color-border-subtle);
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  word-break: break-all;
}

.product-option:first-child {
  border-top: 0;
}

.product-option-empty {
  min-height: var(--tap-min);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
}
