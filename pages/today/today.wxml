<view class="page today-page" bindtouchstart="onPageTouchStart" bindtouchend="onPageTouchEnd">
  <view class="page-head">
    <view class="date-nav-button" aria-role="button" aria-label="前一天" hover-class="tap-hover" bindtap="goPreviousDate">‹</view>
    <view class="date-title-block">
      <view class="page-title">护肤打卡</view>
      <view class="page-date">{{viewDateText}}</view>
    </view>
    <view class="date-nav-button {{canGoNextDate ? '' : 'date-nav-button-disabled'}}" aria-role="button" aria-label="后一天" hover-class="tap-hover" bindtap="goNextDate">›</view>
  </view>

  <view class="segmented time-tabs">
    <view wx:for="{{timeOptions}}" wx:key="value" class="segmented-item {{activeTime === item.value ? 'segmented-item-active' : ''}}" data-value="{{item.value}}" bindtap="switchTime" hover-class="tap-hover">
      <image class="time-icon" src="{{item.value === 'morning' ? '/assets/icons/time-morning.png' : '/assets/icons/time-evening.png'}}" mode="aspectFit" />
      <text>{{item.fullLabel}}</text>
    </view>
  </view>

  <view class="record-card card" wx:if="{{activeRecords.length}}">
    <view class="record-card-head">
      <text class="record-count">已记录 {{activeRecords.length}} 项</text>
    </view>
    <view class="record-swipe-item" wx:for="{{activeRecords}}" wx:key="id" data-id="{{item.id}}" bindtouchstart="onRecordTouchStart" bindtouchend="onRecordTouchEnd">
      <view class="record-swipe-actions {{item.swiped ? 'record-swipe-actions-active' : ''}}">
        <view class="record-swipe-button record-swipe-edit" role="button" hover-class="tap-hover" aria-label="编辑记录 {{item.productNameSnapshot}}" data-id="{{item.id}}" catchtap="editRecord">
          <image class="record-action-icon" src="/assets/icons/action-edit.png" mode="aspectFit" alt="" />
        </view>
        <view class="record-swipe-button record-swipe-delete" role="button" hover-class="tap-hover" aria-label="删除记录 {{item.productNameSnapshot}}" data-id="{{item.id}}" catchtap="deleteRecord">
          <image class="record-action-icon" src="/assets/icons/action-delete.png" mode="aspectFit" alt="" />
        </view>
      </view>
      <view class="record-row {{item.swiped ? 'record-row-open' : ''}} {{draggingRecordId === item.id ? 'record-row-dragging' : ''}}" bindtap="closeRecordSwipe">
        <view class="record-name">{{item.productNameSnapshot}}</view>
        <view class="record-side">
          <text class="record-amount">{{item.amount || '适量'}}</text>
          <view class="record-drag-handle" role="button" aria-label="拖动调整 {{item.productNameSnapshot}} 顺序" data-id="{{item.id}}" catchtouchstart="onRecordDragStart" catchtouchmove="onRecordDragMove" catchtouchend="onRecordDragEnd" catchtouchcancel="onRecordDragEnd">≡</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-record" wx:else>
    <view class="empty-title">还没有记录</view>
    <view class="empty-text">添加{{activeTime === 'morning' ? '早间' : '晚间'}}记录后，会进入这一天和回看统计。</view>
  </view>

  <view class="bottom-action">
    <button class="copy-yesterday-button" hover-class="button-hover" aria-label="{{copyActionText}}{{activeTime === 'morning' ? '早间' : '晚间'}}记录" bindtap="copyPreviousDateRecords">
      <image class="bottom-action-icon" src="/assets/icons/action-copy.svg" mode="aspectFit" alt="" />
      <text>{{copyActionText}}</text>
    </button>
    <button class="primary add-record-button" hover-class="button-hover" aria-label="添加{{activeTime === 'morning' ? '早间' : '晚间'}}记录" bindtap="openCreateForm">
      <view class="add-icon" aria-hidden="true">+</view>
      <text>添加记录</text>
    </button>
  </view>

  <view class="sheet-mask" wx:if="{{showForm}}" bindtap="closeForm"></view>
  <view class="bottom-sheet" wx:if="{{showForm}}" role="dialog" aria-modal="true" aria-labelledby="today-sheet-title" catchtouchmove="noop">
    <view class="sheet-head">
      <view class="sheet-title" id="today-sheet-title">{{editingId ? '编辑护肤记录' : '添加护肤记录'}}</view>
      <button class="close-button" hover-class="button-hover" aria-label="关闭" bindtap="closeForm">×</button>
    </view>

    <view class="segmented sheet-time-tabs">
      <view wx:for="{{timeOptions}}" wx:key="value" class="segmented-item {{form.timeOfDay === item.value ? 'segmented-item-active' : ''}}" data-value="{{item.value}}" bindtap="switchFormTime" hover-class="tap-hover">
        <image class="time-icon" src="{{item.value === 'morning' ? '/assets/icons/time-morning.png' : '/assets/icons/time-evening.png'}}" mode="aspectFit" />
        <text>{{item.label}}</text>
      </view>
    </view>

    <view class="field">
      <text class="field-label">日期</text>
      <picker mode="date" value="{{form.date}}" bindchange="onDatePick">
        <view class="picker-row">
          <text>{{form.date}}</text>
          <text class="chevron">选择 ›</text>
        </view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">分类</text>
      <picker range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryPick">
        <view class="picker-row {{formErrors.categoryName ? 'input-error' : ''}}">
          <text>{{form.categoryName}}</text>
          <text class="chevron">选择 ›</text>
        </view>
      </picker>
      <view class="field-error" wx:if="{{formErrors.categoryName}}">{{formErrors.categoryName}}</view>
    </view>

    <view class="field">
      <view class="field-line">
        <text class="field-label">产品名称</text>
        <view wx:if="{{productOptions.length}}" class="history-chip" role="button" hover-class="tap-hover" bindtap="openProductSelector">从历史选择</view>
      </view>
      <view class="clearable-input">
        <input class="{{formErrors.productName ? 'input-error' : ''}}" placeholder="例如：小棕瓶精华" value="{{form.productName}}" data-field="productName" bindinput="onInput" />
        <view wx:if="{{form.productName}}" class="clear-input-button" role="button" hover-class="tap-hover" aria-label="清空产品名称" data-field="productName" catchtap="clearFormField">×</view>
      </view>
      <view class="field-error" wx:if="{{formErrors.productName}}">{{formErrors.productName}}</view>
    </view>

    <view class="product-selector" wx:if="{{showProductSelector}}">
      <view class="product-selector-head">
        <view class="product-selector-title">选择历史产品</view>
        <view class="product-selector-close" role="button" aria-label="关闭历史产品选择" hover-class="tap-hover" bindtap="closeProductSelector">×</view>
      </view>
      <input class="product-search-input" placeholder="搜索产品名称" value="{{productSearchKeyword}}" bindinput="onProductSearchInput" />
      <scroll-view scroll-y class="product-option-list">
        <view wx:for="{{filteredProductOptions}}" wx:key="*this" class="product-option" role="button" hover-class="tap-hover" data-name="{{item}}" bindtap="selectProduct">{{item}}</view>
        <view wx:if="{{!filteredProductOptions.length}}" class="product-option-empty">没有匹配的历史产品</view>
      </scroll-view>
    </view>

    <view class="field">
      <text class="field-label">用量（可选）</text>
      <input class="{{formErrors.amount ? 'input-error' : ''}}" placeholder="例如：2 滴、一泵" value="{{form.amount}}" data-field="amount" bindinput="onInput" />
      <view class="field-error" wx:if="{{formErrors.amount}}">{{formErrors.amount}}</view>
    </view>

    <view class="sheet-actions">
      <button class="secondary" hover-class="button-hover" bindtap="closeForm">取消</button>
      <button class="primary" hover-class="button-hover" disabled="{{!canSubmit || submitting}}" aria-disabled="{{!canSubmit || submitting}}" bindtap="submitRecord">{{submitting ? '保存中...' : '保存'}}</button>
    </view>
  </view>
</view>
