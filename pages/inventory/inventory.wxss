.inventory-page {
  min-height: 100vh;
}

/* ========== 页头 + FAB ========== */
.page-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.sort-fab,
.add-stock-fab {
  width: var(--tap-min);
  height: var(--tap-min);
  min-width: var(--tap-min);
  min-height: var(--tap-min);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background: var(--color-brand-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-md);
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.add-stock-fab {
  font-size: 40rpx;
  font-weight: var(--fw-regular);
  line-height: 1;
}

.sort-fab-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== 状态分段 ========== */
.inventory-tabs {
  margin-bottom: var(--space-4);
}

.inventory-status-note {
  margin-bottom: var(--space-5);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
}

/* ========== 分类筛选 ========== */
.stock-tools {
  margin-bottom: var(--space-5);
}

.category-filter-scroll {
  width: 100%;
}

.category-filter-tabs {
  width: 100%;
  white-space: nowrap;
  padding-right: var(--space-5);
  box-sizing: border-box;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: var(--tap-min);
  margin-right: var(--space-3);
  padding: 0 var(--space-5);
  border-radius: var(--radius-pill);
  background: var(--color-surface-elevated);
  border: 1rpx solid var(--color-border-subtle);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  box-shadow: var(--shadow-xs);
  transition: background-color var(--motion-fast) var(--ease-standard),
              color var(--motion-fast) var(--ease-standard);
}

.category-tab-active {
  background: var(--color-brand-primary);
  border-color: var(--color-brand-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-sm);
}

/* ========== 库存列表 ========== */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.stock-swipe-item {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.stock-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-3);
  width: 220rpx;
  padding-right: var(--space-4);
  box-sizing: border-box;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.stock-swipe-actions-active {
  opacity: 1;
  pointer-events: auto;
}

.stock-card {
  padding: var(--space-4) var(--space-5);
  border-radius: var(--radius-lg);
}

.stock-card-front {
  position: relative;
  z-index: 1;
  transition: transform var(--motion-fast) var(--ease-standard);
  will-change: transform;
}

.stock-card-front-open-edit {
  transform: translateX(-104rpx);
}

.stock-card-front-open-delete {
  transform: translateX(-208rpx);
}

.stock-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

.stock-main {
  flex: 1;
  min-width: 0;
}

.stock-name {
  overflow: hidden;
  color: var(--color-text-primary);
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  line-height: var(--lh-body);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-meta {
  overflow: hidden;
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--fs-caption);
  line-height: var(--lh-caption);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

/* 主操作按钮：视觉 56rpx + 命中区扩展至 88rpx */
.stock-action-button {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  padding: 0;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.stock-action-button::after {
  content: '';
  position: absolute;
  top: -16rpx;
  left: -16rpx;
  right: -16rpx;
  bottom: -16rpx;
}

.primary-action {
  background: var(--color-brand-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-sm);
}

.stock-action-icon {
  width: 28rpx;
  height: 28rpx;
}

.stock-action-disabled {
  opacity: 0.48;
}

/* 滑动按钮：≥88rpx 命中区 */
.swipe-icon-button {
  width: var(--tap-min);
  height: var(--tap-min);
  min-width: var(--tap-min);
  min-height: var(--tap-min);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: opacity var(--motion-fast) var(--ease-standard);
}

.swipe-edit {
  background: var(--color-surface-elevated);
  box-shadow: var(--shadow-xs);
}

.swipe-action-icon {
  width: 32rpx;
  height: 32rpx;
}

.swipe-delete {
  background: var(--color-danger-bg);
}

/* ========== 空态 ========== */
.empty-record {
  height: 320rpx;
  margin-top: var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 var(--space-5);
}

.empty-record .empty-title {
  color: var(--color-text-primary);
  font-size: var(--fs-subtitle);
  line-height: var(--lh-subtitle);
}

.empty-record .empty-text {
  margin-top: var(--space-2);
  color: var(--color-text-secondary);
  font-size: var(--fs-body-sm);
  line-height: var(--lh-body-sm);
}

/* ========== Sheet 表单 ========== */
.form-grid {
  display: flex;
  gap: var(--space-4);
}

.form-grid-main {
  flex: 1;
  min-width: 0;
}

.form-grid-side {
  width: 200rpx;
}
