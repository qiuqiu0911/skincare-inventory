.inventory-page {
  min-height: 100vh;
}

.page-head {
  padding: 44rpx 18rpx 34rpx;
}

.page-title {
  color: #333333;
  font-size: 50rpx;
  font-weight: 750;
  line-height: 62rpx;
}

.inventory-tabs {
  margin: 0 18rpx 18rpx;
  border-radius: 24rpx;
}

.inventory-status-note {
  margin: 0 22rpx 22rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 34rpx;
}

.category-filter-scroll {
  margin: 0 18rpx 24rpx;
}

.category-filter-tabs {
  width: 100%;
  white-space: nowrap;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  margin-right: 14rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 24, 39, 0.055);
  color: #64748b;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 60rpx;
  box-shadow: 0 8rpx 22rpx rgba(17, 24, 39, 0.03);
}

.category-tab-active {
  background: #111827;
  border-color: #111827;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(17, 24, 39, 0.14);
}

.stock-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stock-swipe-item {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.stock-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  width: 180rpx;
  padding-right: 18rpx;
  box-sizing: border-box;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.stock-swipe-actions-active {
  opacity: 1;
  pointer-events: auto;
}

.stock-card {
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
}

.stock-card-front {
  position: relative;
  z-index: 1;
  transition: transform 0.18s ease;
  will-change: transform;
}

.stock-card-front-open-edit {
  transform: translateX(-94rpx);
}

.stock-card-front-open-delete {
  transform: translateX(-176rpx);
}

.stock-card-front-open-edit .stock-head,
.stock-card-front-open-edit .stock-bottom-row {
  padding-left: 94rpx;
  box-sizing: border-box;
}

.stock-card-front-open-delete .stock-head,
.stock-card-front-open-delete .stock-bottom-row {
  padding-left: 176rpx;
  box-sizing: border-box;
}

.stock-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  transition: padding-left 0.18s ease;
}

.stock-main {
  flex: 1;
  min-width: 0;
}

.stock-name {
  color: #333333;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 40rpx;
  word-break: break-all;
}

.stock-meta {
  margin-top: 6rpx;
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 32rpx;
}

.stock-foot {
  display: none;
}

.stock-bottom-row {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  transition: padding-left 0.18s ease;
}

.stock-dates {
  flex: 1;
  min-width: 0;
  color: #9ca3af;
  font-size: 22rpx;
  font-style: italic;
  line-height: 32rpx;
  word-break: break-all;
}

.stock-dates-placeholder {
  min-height: 1rpx;
}

.stock-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.stock-action-button {
  min-height: 60rpx;
  line-height: 60rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.primary-action {
  min-width: 156rpx;
  background: #111827;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(17, 24, 39, 0.14);
}

.stock-action-disabled {
  opacity: 0.48;
}

.swipe-icon-button {
  width: 66rpx;
  height: 66rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.swipe-edit {
  background: #f8fafc;
  color: #64748b;
}

.edit-icon {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 66rpx;
}

.swipe-delete {
  background: #fff1f2;
}

.delete-trash {
  position: relative;
  width: 30rpx;
  height: 34rpx;
}

.trash-lid {
  position: absolute;
  left: 3rpx;
  top: 3rpx;
  width: 24rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ef4444;
}

.trash-lid::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -5rpx;
  width: 8rpx;
  height: 5rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #ef4444;
}

.trash-body {
  position: absolute;
  left: 5rpx;
  top: 12rpx;
  width: 20rpx;
  height: 18rpx;
  border: 4rpx solid #ef4444;
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.empty-record {
  height: 320rpx;
  margin: 12rpx 4rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 126rpx;
  padding: 0 48rpx;
  z-index: 5;
  box-sizing: border-box;
}

.add-stock-button {
  width: 100%;
  border-radius: 30rpx;
  min-height: 84rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.2);
}

.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  max-height: 90vh;
  padding: 44rpx 38rpx 42rpx;
  border-radius: 64rpx 64rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(17, 24, 39, 0.12);
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.sheet-title {
  color: #333333;
  font-size: 40rpx;
  font-weight: 750;
  line-height: 50rpx;
}

.close-button {
  min-width: 64rpx;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  color: #9ca3af;
  font-size: 40rpx;
  line-height: 64rpx;
}

.form-grid {
  display: flex;
  gap: 20rpx;
}

.form-grid-main {
  flex: 1;
  min-width: 0;
}

.form-grid-side {
  width: 180rpx;
}

.sheet-actions {
  display: flex;
  gap: 18rpx;
  padding-top: 12rpx;
}

.sheet-actions button {
  flex: 1;
}
