<view class="page inventory-page">
  <view class="page-head">
    <view>
      <view class="page-title">产品库存</view>
    </view>
    <view class="page-actions">
      <view class="sort-fab" role="button" aria-label="切换库存排序" hover-class="tap-hover" bindtap="toggleSortMode">
        <image class="sort-fab-icon" src="/assets/icons/action-sort.png" mode="aspectFit" alt="" />
      </view>
      <view class="add-stock-fab" role="button" aria-label="新增库存" hover-class="tap-hover" bindtap="openCreateForm">+</view>
    </view>
  </view>

  <view class="segmented inventory-tabs">
    <view wx:for="{{statusTabs}}" wx:key="value" class="segmented-item {{status === item.value ? 'segmented-item-active' : ''}}" data-status="{{item.value}}" bindtap="switchStatus" hover-class="tap-hover">
      {{item.label}} ({{item.count}})
    </view>
  </view>

  <view class="inventory-status-note">{{statusNote}}</view>

  <view class="stock-tools">
    <view class="category-filter-scroll">
      <scroll-view scroll-x enable-flex class="category-filter-tabs">
        <view wx:for="{{filterTabs}}" wx:key="value" class="category-tab {{item.active ? 'category-tab-active' : ''}}" data-category="{{item.value}}" bindtap="switchFilterCategory">
          {{item.label}}
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="stock-list" wx:if="{{stocks.length}}">
    <view class="stock-swipe-item" wx:for="{{stocks}}" wx:key="id" data-id="{{item.id}}" data-status="{{item.status}}" bindtouchstart="onStockTouchStart" bindtouchend="onStockTouchEnd">
      <view class="stock-swipe-actions {{item.swiped ? 'stock-swipe-actions-active' : ''}}">
        <view class="swipe-icon-button swipe-copy" role="button" hover-class="tap-hover" aria-label="复制库存 {{item.productNameSnapshot}}" data-id="{{item.id}}" catchtap="copyStock">
          <image class="swipe-action-icon" src="/assets/icons/action-copy.svg" mode="aspectFit" alt="" />
        </view>
        <view class="swipe-icon-button swipe-edit" role="button" hover-class="tap-hover" aria-label="编辑库存 {{item.productNameSnapshot}}" data-id="{{item.id}}" catchtap="swipeEditStock">
          <image class="swipe-action-icon" src="/assets/icons/action-edit.png" mode="aspectFit" alt="" />
        </view>
        <view wx:if="{{item.status === 'stocked'}}" class="swipe-icon-button swipe-delete {{updatingStockId === item.id ? 'stock-action-disabled' : ''}}" role="button" hover-class="tap-hover" aria-label="删除库存 {{item.productNameSnapshot}}" aria-disabled="{{updatingStockId === item.id}}" data-id="{{item.id}}" catchtap="swipeDeleteStock">
          <image class="swipe-action-icon" src="/assets/icons/action-delete.png" mode="aspectFit" alt="" />
        </view>
      </view>

      <view class="stock-card card stock-card-front {{item.swipeClass}}" bindtap="closeSwipe">
        <view class="stock-content">
          <view class="stock-main">
            <view class="stock-name">{{item.productNameSnapshot}}</view>
            <view class="stock-meta">
              <text>分类: {{item.categoryNameSnapshot}} | {{item.capacitySnapshot || '不详'}} · {{item.quantity}} 件</text>
              <text wx:if="{{item.expiryDateSnapshot && item.status === 'stocked'}}"> · 到期: {{item.expiryDateSnapshot}}</text>
              <text wx:if="{{item.openedDate && item.status === 'active'}}"> · 开瓶: {{item.openedDate}}</text>
              <text wx:if="{{item.finishedDate && item.status === 'finished'}}"> · 空瓶: {{item.finishedDate}}</text>
            </view>
          </view>
          <view class="stock-actions" wx:if="{{item.status === 'stocked' || item.status === 'active'}}">
            <view wx:if="{{item.status === 'stocked'}}" class="stock-action-button primary-action {{updatingStockId === item.id ? 'stock-action-disabled' : ''}}" role="button" hover-class="tap-hover" aria-label="记录开瓶" aria-disabled="{{updatingStockId === item.id}}" data-id="{{item.id}}" catchtap="openStock">
              <image class="stock-action-icon" src="/assets/icons/stock-open.png" mode="aspectFit" alt="" />
            </view>
            <view wx:if="{{item.status === 'active'}}" class="stock-action-button primary-action {{updatingStockId === item.id ? 'stock-action-disabled' : ''}}" role="button" hover-class="tap-hover" aria-label="标记用完" aria-disabled="{{updatingStockId === item.id}}" data-id="{{item.id}}" catchtap="finishStock">
              <image class="stock-action-icon" src="/assets/icons/stock-finish.png" mode="aspectFit" alt="" />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-record" wx:else>
    <view class="empty-title">{{emptyTitle}}</view>
    <view class="empty-text">{{filterCategoryName ? '当前分类下暂无该状态库存。' : emptyText}}</view>
    <button wx:if="{{filterCategoryName}}" class="secondary empty-action" hover-class="button-hover" bindtap="resetFilterCategory">查看全部分类</button>
    <button wx:else class="primary empty-action" hover-class="button-hover" bindtap="openCreateForm">新增库存</button>
  </view>

  <view class="sheet-mask" wx:if="{{showForm}}" bindtap="closeForm"></view>
  <view class="bottom-sheet" wx:if="{{showForm}}" role="dialog" aria-modal="true" aria-labelledby="inventory-sheet-title" catchtouchmove="noop">
    <view class="sheet-head">
      <view class="sheet-title" id="inventory-sheet-title">{{editingStockId ? '编辑库存' : '添加库存'}}</view>
      <button class="close-button" hover-class="button-hover" aria-label="关闭" bindtap="closeForm">×</button>
    </view>

    <view class="field">
      <text class="field-label">产品名称</text>
      <view class="clearable-input">
        <input class="{{formErrors.productName ? 'input-error' : ''}}" placeholder="例如：神仙水" value="{{form.productName}}" data-field="productName" bindinput="onInput" />
        <view wx:if="{{form.productName}}" class="clear-input-button" role="button" hover-class="tap-hover" aria-label="清空产品名称" data-field="productName" catchtap="clearFormField">×</view>
      </view>
      <view class="field-error" wx:if="{{formErrors.productName}}">{{formErrors.productName}}</view>
    </view>

    <view class="field">
      <text class="field-label">分类</text>
      <picker range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryPick">
        <view class="picker-row">
          <text>{{form.categoryName}}</text>
          <text class="chevron">选择 ›</text>
        </view>
      </picker>
    </view>

    <view class="form-grid">
      <view class="field form-grid-main">
        <text class="field-label">规格容量</text>
        <input class="{{formErrors.capacity ? 'input-error' : ''}}" placeholder="如：150ml" value="{{form.capacity}}" data-field="capacity" bindinput="onInput" />
        <view class="field-error" wx:if="{{formErrors.capacity}}">{{formErrors.capacity}}</view>
      </view>
      <view class="field form-grid-side">
        <text class="field-label">数量</text>
        <input class="{{formErrors.quantity ? 'input-error' : ''}}" type="number" value="{{form.quantity}}" data-field="quantity" bindinput="onInput" />
        <view class="field-error" wx:if="{{formErrors.quantity}}">{{formErrors.quantity}}</view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">限用日期（可选）</text>
      <picker mode="date" value="{{form.expiryDate}}" bindchange="onExpiryPick">
        <view class="picker-row {{formErrors.expiryDate ? 'input-error' : ''}}">
          <text class="{{form.expiryDate ? '' : 'picker-placeholder'}}">{{form.expiryDate || '选择日期'}}</text>
          <text class="chevron">选择 ›</text>
        </view>
      </picker>
      <view class="field-error" wx:if="{{formErrors.expiryDate}}">{{formErrors.expiryDate}}</view>
    </view>

    <view class="sheet-actions">
      <button class="secondary" hover-class="button-hover" bindtap="closeForm">取消</button>
      <button class="primary" hover-class="button-hover" disabled="{{!canSubmit || submitting}}" aria-disabled="{{!canSubmit || submitting}}" bindtap="submitStock">{{submitting ? '保存中...' : '保存'}}</button>
    </view>
  </view>
</view>
